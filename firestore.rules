rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@gmail.com' ||
        request.auth.token.email == 'vishu@gmail.com' ||
        request.auth.token.email == 'shrivastavavishu890@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users public profiles and private data
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId);
      // Allow owners updating counters/coins, and admins managing bans/moderation
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Admins registry
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Notices list
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Markets rooms
    match /markets/{marketId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Game Results published history
    match /results/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Arena Entries (bets)
    match /entries/{entryId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Check query filters to prevent non-admin query leaks
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Financial Transactions logs
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Check query filters to prevent transaction list leaks
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Deposit claims
    match /deposits/{depId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Filter list check
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Withdrawal requests
    match /withdrawals/{withId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Filter list check
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
